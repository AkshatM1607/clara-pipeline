# Python cache and compiled files
__pycache__/
*.py[cod]
*$py.class

# Virtual environments
.venv/
venv/
env/

# Environment variables
.env

# Distribution and packaging
build/
dist/
*.egg-info/

# Test and tooling caches
.pytest_cache/
.mypy_cache/
.ruff_cache/

# OS/editor artifacts
.DS_Store
Thumbs.db
.vscode/
.idea/

# Pipeline outputs - track the files, ignore only local runtime data
outputs/accounts/**/
!outputs/accounts/**/*.json
!outputs/accounts/**/*.md
!outputs/accounts/.gitkeep

# Data folder (confidential)
data/
